# syntax=docker/dockerfile:1.7
FROM {{ .BaseImage }}

# Common tools for all session images.
RUN --mount=type=cache,id=relayshell-apk-cache,target=/var/cache/apk \
  --mount=type=cache,id=relayshell-apt-cache,target=/var/cache/apt,sharing=locked \
  --mount=type=cache,id=relayshell-apt-lists,target=/var/lib/apt/lists,sharing=locked \
  set -eux; \
  if command -v apk >/dev/null 2>&1; then \
    apk add --update-cache bash git ca-certificates; \
  elif command -v apt-get >/dev/null 2>&1; then \
    apt-get update; \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends bash git ca-certificates; \
    apt-get clean; \
  else \
    echo 'No supported package manager found (apk/apt-get)' >&2; \
    exit 1; \
  fi

{{ if hasLang .Languages "go" }}
# Go stack tools.
