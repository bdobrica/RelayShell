# syntax=docker/dockerfile:1.7
ARG BASE_IMAGE=relayshell-codex:latest
FROM ${BASE_IMAGE}

ARG ENABLE_GO=0
ARG ENABLE_PYTHON=0
ARG ENABLE_NODEJS=0

# Common tools for all session images.
RUN --mount=type=cache,id=relayshell-apk-cache,target=/var/cache/apk \
  --mount=type=cache,id=relayshell-apt-cache,target=/var/cache/apt,sharing=locked \
  --mount=type=cache,id=relayshell-apt-lists,target=/var/lib/apt/lists,sharing=locked \
  set -eux; \
  if command -v apk >/dev/null 2>&1; then \
    apk add --update-cache bash git ca-certificates; \
  elif command -v apt-get >/dev/null 2>&1; then \
    apt-get update; \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends bash git ca-certificates; \
    apt-get clean; \
  else \
    echo 'No supported package manager found (apk/apt-get)' >&2; \
    exit 1; \
  fi

# Go stack tools.
RUN --mount=type=cache,id=relayshell-apk-cache,target=/var/cache/apk \
  --mount=type=cache,id=relayshell-apt-cache,target=/var/cache/apt,sharing=locked \
  --mount=type=cache,id=relayshell-apt-lists,target=/var/lib/apt/lists,sharing=locked \
  set -eux; \
  if [ "${ENABLE_GO}" = "1" ]; then \
    if command -v apk >/dev/null 2>&1; then \
      apk add --update-cache go python3 py3-pip make; \
    elif command -v apt-get >/dev/null 2>&1; then \
      apt-get update; \
      DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends golang-go python3 python3-pip make build-essential; \
      apt-get clean; \
    else \
      echo 'No supported package manager found (apk/apt-get)' >&2; \
      exit 1; \
    fi; \
  fi

# Python stack tools.
RUN --mount=type=cache,id=relayshell-apk-cache,target=/var/cache/apk \
  --mount=type=cache,id=relayshell-apt-cache,target=/var/cache/apt,sharing=locked \
  --mount=type=cache,id=relayshell-apt-lists,target=/var/lib/apt/lists,sharing=locked \
  set -eux; \
  if [ "${ENABLE_PYTHON}" = "1" ]; then \
    if command -v apk >/dev/null 2>&1; then \
      apk add --update-cache python3 py3-pip build-base make; \
    elif command -v apt-get >/dev/null 2>&1; then \
      apt-get update; \
      DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends python3 python3-pip build-essential make; \
      apt-get clean; \
    else \
      echo 'No supported package manager found (apk/apt-get)' >&2; \
      exit 1; \
    fi; \
  fi

# Node.js stack tools.
RUN --mount=type=cache,id=relayshell-apk-cache,target=/var/cache/apk \
  --mount=type=cache,id=relayshell-apt-cache,target=/var/cache/apt,sharing=locked \
  --mount=type=cache,id=relayshell-apt-lists,target=/var/lib/apt/lists,sharing=locked \
  set -eux; \
  if [ "${ENABLE_NODEJS}" = "1" ]; then \
    if command -v apk >/dev/null 2>&1; then \
      apk add --update-cache nodejs npm python3 make build-base; \
    elif command -v apt-get >/dev/null 2>&1; then \
      apt-get update; \
      DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends nodejs npm python3 python3-pip make build-essential; \
      apt-get clean; \
    else \
      echo 'No supported package manager found (apk/apt-get)' >&2; \
      exit 1; \
    fi; \
  fi
