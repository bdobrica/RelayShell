# ---------- Tuwunel / Matrix test homeserver ----------
CONDUWUIT_SERVER_NAME=localhost
CONDUWUIT_DATABASE_PATH=/var/lib/tuwunel
CONDUWUIT_PORT=8008
CONDUWUIT_ALLOW_REGISTRATION=true
CONDUWUIT_REGISTRATION_TOKEN=integration-test-token
CONDUWUIT_ALLOW_FEDERATION=false
CONDUWUIT_ALLOW_PUBLIC_ROOM_DIRECTORY=false
CONDUWUIT_LOG=info

# ---------- Matrix bootstrap defaults ----------
MATRIX_BOOTSTRAP_BOT_USERNAME=relayshell
MATRIX_BOOTSTRAP_BOT_PASSWORD=StrongPass123!
MATRIX_BOOTSTRAP_HUMAN_USERNAME=alice
MATRIX_BOOTSTRAP_HUMAN_PASSWORD=StrongPass123!
MATRIX_BOOTSTRAP_GOVERNOR_ROOM_NAME="RelayShell Governor"

# ---------- RelayShell governor ----------
RELAY_MATRIX_HOMESERVER=http://localhost:8008
RELAY_MATRIX_USER_ID=@relayshell:localhost
RELAY_MATRIX_ACCESS_TOKEN=replace_me
RELAY_MATRIX_GOVERNOR_ROOM_ID=!replace_me:localhost
RELAY_ALLOWED_USERS=@your-user:localhost
RELAY_LOG_LEVEL=info

RELAY_WORKSPACE_BASE_DIR=/tmp/relayshell
RELAY_EVENTS_DB_PATH=/tmp/relayshell/governor_events.db
RELAY_EVENTS_RETENTION_DAYS=30
RELAY_CONTAINER_RUNTIME=docker
RELAY_CONTAINER_IMAGE=alpine:3.20

RELAY_AGENT_CODEX_IMAGE=relayshell-codex:latest
RELAY_AGENT_CODEX_COMMAND=codex
RELAY_AGENT_COPILOT_IMAGE=alpine:3.20
RELAY_AGENT_COPILOT_COMMAND=cat
# Optional commit author override used by /commit. If empty, RelayShell uses host global git config.
RELAY_GIT_AUTHOR_NAME=
RELAY_GIT_AUTHOR_EMAIL=
# Milliseconds of bridge output inactivity before flushing buffered terminal output.
RELAY_BRIDGE_OUTPUT_BATCH_IDLE_MS=300
# Hard cap for how long buffered output may wait before forced flush (0 disables hard cap).
RELAY_BRIDGE_OUTPUT_FLUSH_MAX_MS=2000
# Enable debug logs for stdin/stdout/stderr bridge buffers (printable + <HEX> for control bytes).
RELAY_BRIDGE_DEBUG_IO=false
# Session room archival policy on /exit: keep, leave, or forget.
RELAY_SESSION_ROOM_ARCHIVE_POLICY=forget

# Comma-separated list of host env vars that should be passed into worker containers.
RELAY_CONTAINER_PASSTHROUGH_ENV=OPENAI_API_KEY,OPENAI_BASE_URL,OPENAI_ORG_ID,OPENAI_PROJECT

# ---------- OpenAI / Codex ----------
OPENAI_API_KEY=replace_me
# OPENAI_BASE_URL=
# OPENAI_ORG_ID=
# OPENAI_PROJECT=
